      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 12px 30px rgba(7, 26, 47, .12);
    }
    .photo-card img {
      display: block;
      width: 100%;
      height: 280px;
      object-fit: cover;
    }
    .photo-card figcaption {
      padding: 18px 20px 22px;
      color: #071a2f;
    }
    .photo-card figcaption strong {
      display: block;
      margin-bottom: 6px;
      font-size: 1.05rem;
