    .solution-photo {
      margin-top: 28px;
      width: 100%;
      max-height: 360px;
      object-fit: cover;
      border-radius: 16px;
      box-shadow: 0 12px 30px rgba(7, 26, 47, .12);
    }
    @media (max-width: 850px) {
      .photo-grid { grid-template-columns: 1fr; }
      .photo-card img { height: 240px; }
