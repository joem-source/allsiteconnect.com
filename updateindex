            <label>Email<input required name="email" type="email"></label>
            <label>Phone<input name="phone" type="tel"></label>
          </div>
          <label>Construction Site Address<input name="site_address" type="text"></label>
          <div class="form-row">
            <label>Project Start Date<input name="start_date" type="date"></label>
            <label>Estimated Rental Length<input name="rental_length" type="text" placeholder="Example: 6 months"></label>
          </div>
